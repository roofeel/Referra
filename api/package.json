{
  "name": "api",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "db:generate": "cd ../packages/db && bunx prisma generate --schema prisma/schema.prisma",
    "db:migrate": "cd ../packages/db && bunx prisma migrate deploy --schema prisma/schema.prisma",
    "dev": "bun run db:generate && bun --hot index.ts",
    "postinstall": "cd ../packages/db && bun install && bunx prisma generate --schema prisma/schema.prisma",
    "start": "bun index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "4.0.95",
    "@aws-sdk/credential-providers": "3.1032.0",
    "@sentry/bun": "^10.50.0",
    "ai": "^6.0.78",
    "hono": "^4.11.9",
    "zod": "^4.3.6"
  }
}
