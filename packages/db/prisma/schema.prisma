// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  name      String    @unique
  urlRules  UrlRule[]
  reports   Report[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model UrlRule {
  id                   String   @id @default(cuid())
  clientId             String?
  client               Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name                 String
  shortName            String
  status               String   @default("active")
  logicSource          String   @default("")
  activeVersion        String   @default("v1.0.0")
  updatedBy            String?  @default("System")
  environmentVariables Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([clientId])
}

model Report {
  id                String   @id @default(cuid())
  clientId          String?
  client            Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  referrerRaws      ReferrerRaw[]
  logs              Log[]
  taskName          String
  ruleId            String
  source            String   @default("CSV Import")
  sourceIcon        String   @default("description")
  status            String   @default("Running")
  progress          Int      @default(0)
  progressLabel     String   @default("0% Processed")
  attribution       String   @default("--")
  reportType        String   @default("registration")
  fieldMappings     Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model ReferrerRaw {
  id           String @id @default(cuid())
  reportId     String
  report       Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  referrerType String @map("referrer_type")
  referrerDesc String @map("referrer_desc")
  duration     Int
  json         Json

  @@index([reportId])
}

model Log {
  id        String   @id @default(cuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  level     String
  message   String
  createdAt DateTime @default(now())

  @@index([reportId])
  @@index([createdAt])
}
